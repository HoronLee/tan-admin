# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG=

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT=

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN=
# Database URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres" # Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `npx -y @better-auth/cli secret`

# Optional: bootstrap a super-admin account when `pnpm db:seed` runs.
# When both are set, the seed script creates the user via Better Auth (idempotent)
# and binds it to the `super-admin` role so policy-protected CRUD works out-of-the-box.
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=admin@123

# === Tenancy Mode ===
# 交付型单租户(single) vs 多租户 SaaS(multi). VITE_ mirror 必须同步值.
TENANCY_MODE=single
VITE_TENANCY_MODE=single

# 是否启用 BA teams 插件. VITE_ mirror 必须同步值.
TEAM_ENABLED=false
VITE_TEAM_ENABLED=false

# === Seed defaults ===
# 仅在 TENANCY_MODE=single 时用于 seed 创建默认组织
SEED_DEFAULT_ORG_NAME=默认组织
SEED_DEFAULT_ORG_SLUG=default

# === Email transport ===
# console=dev only log / smtp=国内生产首推 / resend=海外生产
# NODE_ENV=production 时禁止使用 console
EMAIL_TRANSPORT=console
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=Tan Admin
# 逗号分隔邮箱白名单; 命中则跳过邮箱验证流程 (dev 便捷)
EMAIL_VERIFICATION_SKIP_LIST=

# === SMTP (EMAIL_TRANSPORT=smtp 时必填) ===
# 阿里云邮件推送示例:
# SMTP_HOST=smtpdm.aliyun.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=<控制台生成的 SMTP 密码, 不是登录密码>
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# === Resend (EMAIL_TRANSPORT=resend 时必填) ===
RESEND_API_KEY=
