# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG=

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT=

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN=
# Database URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres" # Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `npx -y @better-auth/cli secret`

# Optional: bootstrap a super-admin account when `pnpm db:seed` runs.
# When both are set, the seed script creates the user via Better Auth (idempotent)
# and binds it to the `super-admin` role so policy-protected CRUD works out-of-the-box.
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=admin@123
