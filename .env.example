# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG=

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT=

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN=
# Database URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres" # Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `npx -y @better-auth/cli secret`

# Optional: bootstrap a super-admin account when `pnpm db:seed` runs.
# When both are set, the seed script creates the user via Better Auth (idempotent)
# and binds it to the `super-admin` role so policy-protected CRUD works out-of-the-box.
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=admin@123

# === Product Mode ===
# 产品交付形态（不是物理多租户！底层始终是 BA organization 的 multi-workspace
# 模型，隔离由 ZenStack policy 在业务层兜底）。
#   private = 甲方交付 / 私有化部署：seed 默认组织 + 超管 owner，注册用户
#             自动入伙默认组织，禁止自建 org（`/organizations` 新建/解散灰掉）。
#   saas    = 公开 B2B SaaS workspace 模型（Slack / Notion / Linear 那种）：
#             任何人注册即可为自己 workspace 的 owner，可自建/解散。
# VITE_ mirror 必须与服务端同值（UI 门控避免 loader 往返）。
# 详见 .trellis/spec/backend/product-modes.md。
PRODUCT_MODE=private
VITE_PRODUCT_MODE=private

# 是否启用 BA organization.teams 子分组（workspace 内部再分小组，
# 与产品形态正交，saas / private 都可独立开关）。
TEAM_ENABLED=false
VITE_TEAM_ENABLED=false

# === Seed defaults ===
# 仅在 PRODUCT_MODE=private 时用于 seed 创建默认组织
SEED_DEFAULT_ORG_NAME=默认组织
SEED_DEFAULT_ORG_SLUG=default

# === Email transport ===
# console=dev only log / smtp=国内生产首推 / resend=海外生产
# NODE_ENV=production 时禁止使用 console
EMAIL_TRANSPORT=console
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=Tan Admin
# Dev 便捷: APP_ENV=dev 时以 @dev.com 结尾的邮箱注册后自动 emailVerified=true,
# 不发验证邮件 (测试账号专用). prod 下无效.

# === SMTP (EMAIL_TRANSPORT=smtp 时用) ===
# SMTP_HOST 必填; SMTP_USER/SMTP_PASS 可选 (同时有或同时无).
# 本地测试 (mailpit/maildev/maildev 等无认证 relay): 不填 SMTP_USER/PASS.
# 生产 (阿里云邮件推送 / SendGrid / SES 等):
#   SMTP_HOST=smtpdm.aliyun.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=noreply@yourdomain.com
#   SMTP_PASS=<控制台生成的 SMTP 密码, 不是登录密码>
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# === Resend (EMAIL_TRANSPORT=resend 时必填) ===
RESEND_API_KEY=
