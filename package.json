{
  "name": "tan-servora",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "vite build && cp instrument.server.mjs dist/server",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "start": "node --import ./dist/server/instrument.server.mjs dist/server/server.js",
    "post-cta-init": "npx -y create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env.local -- zen generate",
    "db:push": "dotenv -e .env.local -- zen db push",
    "db:migrate": "dotenv -e .env.local -- zen migrate dev",
    "db:studio": "dotenv -e .env.local -- zen studio",
    "db:seed": "dotenv -e .env.local -- tsx src/seed.ts",
    "auth:migrate": "dotenv -e .env.local -- npx @better-auth/cli@latest migrate",
    "email:dev": "email dev --dir ./src/emails",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy cookie preferredLanguage baseLocale"
  },
  "dependencies": {
    "@better-auth-ui/core": "^1.6.3",
    "@better-auth-ui/react": "^1.6.3",
    "@better-auth/passkey": "^1.6.6",
    "@faker-js/faker": "^10.4.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@orpc/client": "^1.13.14",
    "@orpc/json-schema": "^1.13.14",
    "@orpc/openapi": "^1.13.14",
    "@orpc/server": "^1.13.14",
    "@orpc/tanstack-query": "^1.13.14",
    "@orpc/zod": "^1.13.14",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/tanstackstart-react": "^10.49.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-pacer": "^0.22.0",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.167.22",
    "@tanstack/store": "latest",
    "@zenstackhq/orm": "^3.6.3",
    "@zenstackhq/plugin-policy": "^3.6.3",
    "@zenstackhq/schema": "^3.6.3",
    "@zenstackhq/server": "^3.6.3",
    "@zenstackhq/tanstack-query": "^3.6.3",
    "better-auth": "^1.6.5",
    "bowser": "^2.14.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "prisma": "^7.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "resend": "^6.12.2",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@inlang/paraglide-js": "^2.16.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@zenstackhq/cli": "^3.6.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "react-email": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@better-auth/cli",
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "lightningcss",
      "msw",
      "prisma"
    ]
  }
}
